# Copy these variable names into Vercel exactly as written.
# Do not commit real secrets to the repository.

# Required in every environment.
# Supabase Dashboard -> Connect or Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Required in every environment.
# Supabase Dashboard -> Connect or Settings -> API -> Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Set this explicitly in Vercel to the production domain.
# For local development, use http://localhost:3000 in .env.local.
NEXT_PUBLIC_SITE_URL=

# Keep this false in preview and production.
# Temporarily switch to true only while bootstrapping the first admin account.
NEXT_PUBLIC_ENABLE_BOOTSTRAP_SIGNUP=false

# Optional server-only key for future admin jobs or imports.
# Leave blank unless a server-only flow actually needs it.
# Never expose this in browser code or in NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# App metadata
NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin
