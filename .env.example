# Copy these variable names into Vercel exactly as written.
# For local development, copy .env.local.example to .env.local.

# PASTE HERE LATER:
# Supabase Dashboard -> Connect (or Settings -> API) -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# PASTE HERE LATER:
# Supabase Dashboard -> Connect (or Settings -> API) -> Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_REAL_KEY

# Local development: keep http://localhost:3000
# Vercel production: use your primary https://your-domain.vercel.app or custom domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only values (optional now, recommended for future admin jobs)
# Supabase Dashboard -> Settings -> API -> service_role / secret key
# Never expose this in browser code or in NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVER_ONLY_KEY_IF_NEEDED

# App metadata
NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin
