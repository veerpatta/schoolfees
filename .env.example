# Copy this file to .env.local for local development.
# In Vercel, set these as project environment variables.
# Do not commit real secrets to the repository.

# --- Required in every environment ---

# Supabase Dashboard -> Connect or Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard -> Connect or Settings -> API -> Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production domain in Vercel; http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for server-side staff bootstrap, admin staff management,
# and auth admin flows. Never expose in browser code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# App metadata
NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin

# production -> public schema, test -> isolated test schema.
APP_MODE=production

# --- Sentry (error monitoring) ---

# Public DSN - safe to expose in the browser. Same value in all environments.
NEXT_PUBLIC_SENTRY_DSN=https://b5204339a4d02c8c92eedbafc60f3a24@o4511485074407424.ingest.de.sentry.io/4511485112877136

# Build-time only. Org auth token used to upload source maps so stack traces
# are readable. Create at: Sentry -> Settings -> Auth Tokens (scopes:
# project:read+write, release:admin). Set in Vercel + CI, NOT in browser code.
# If left empty, builds still succeed — they just skip source-map upload.
SENTRY_AUTH_TOKEN=

# --- Optional ---

# Override OpenAI model selection in server-side integrations
# (defaults in lib/config/openai.ts).
OPENAI_MODEL=gpt-5.5

# --- Schoolfees MCP connector for ChatGPT / agents ---

# Local MCP server bind settings. Keep host as 127.0.0.1 for local testing.
SCHOOLFEES_MCP_HOST=127.0.0.1
SCHOOLFEES_MCP_PORT=4317
SCHOOLFEES_MCP_PATH=/mcp
SCHOOLFEES_MCP_ALLOWED_HOSTS=127.0.0.1,localhost

# Default session used when the agent does not specify one.
# Use TEST-2026-27 while testing; switch to 2026-27 only when connecting
# intentionally for live office collection context.
SCHOOLFEES_MCP_DEFAULT_SESSION=TEST-2026-27

# Optional shared bearer token for private deployments/tunnels.
# Leave blank for local Developer Mode testing if your MCP client cannot send
# an Authorization header.
SCHOOLFEES_MCP_TOKEN=

# Optional schema override. Defaults to APP_MODE=test -> test, otherwise public.
SCHOOLFEES_MCP_SUPABASE_SCHEMA=

# Cloudflare Worker deployment uses the same Supabase URL and service role
# secret, plus this optional bearer token for ChatGPT/Codex remote access.
# Store real values as Worker secrets, not in committed files.
SCHOOLFEES_WORKER_MCP_URL=
SCHOOLFEES_WORKER_MCP_TOKEN=

# --- Bootstrap script only (scripts/bootstrap-staff.mjs) ---
BOOTSTRAP_MAIN_ADMIN_PASSWORD=
BOOTSTRAP_ACCOUNTS_PASSWORD=
BOOTSTRAP_STAFF_PASSWORD=
