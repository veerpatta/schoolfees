# Copy this file to .env.local for local development.
# In Vercel, set these as project environment variables.
# Do not commit real secrets to the repository.

# --- Required in every environment ---

# Supabase Dashboard -> Connect or Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard -> Connect or Settings -> API -> Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production domain in Vercel; http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for server-side staff bootstrap, admin staff management,
# and auth admin flows. Never expose in browser code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# App metadata
NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin

# production -> public schema, test -> isolated test schema.
APP_MODE=production

# --- Optional ---

# Override OpenAI model selection in server-side integrations
# (defaults in lib/config/openai.ts).
OPENAI_MODEL=gpt-5.5

# --- Bootstrap script only (scripts/bootstrap-staff.mjs) ---
BOOTSTRAP_MAIN_ADMIN_PASSWORD=
BOOTSTRAP_ACCOUNTS_PASSWORD=
BOOTSTRAP_STAFF_PASSWORD=
