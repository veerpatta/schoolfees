# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# scratch / editor temp files
*.tmp

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# VPPS import workbooks and backup snapshots (sensitive student data)
/data/imports/*.xlsx
/data/imports/backups/
/docs/import-previews/*/apply-reports/
/docs/import-previews/*/backups/
.playwright-mcp/

# Smoke-test runs and import previews — contain real student PII, exports,
# Playwright traces, and HAR files with auth tokens. Never commit.
/docs/smoke-reports/
/docs/history/import-previews/
*.har

# DB dumps and migration scratch (contain real student/auth data — never commit)
/.region-migration/
/scratch/
.codex-*.txt
.codex-*.log

# 2026-05-24 revamp artefacts — contain real student/parent PII; never commit
/backups/
/scripts/_revamp/out/

# Claude Code local/personal settings (project settings.json is committed)
/.claude/settings.local.json
/.claude/launch.json

# Prev-year dues import snapshots — contain real student names/dues (PII); never commit
/prevyear_*.json
/prevyear_batch_id.txt

# Claude Code Superpowers plugin plans (ephemeral agent artefacts)
/docs/superpowers/
