# Copy this file to .env.local before running the app.

# Required local values from Supabase Dashboard -> Connect or Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local auth redirect URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Keep false unless you are temporarily creating the very first admin account.
NEXT_PUBLIC_ENABLE_BOOTSTRAP_SIGNUP=false

# Optional server-only key for future admin jobs or imports.
# Leave blank unless a server-only flow actually needs it.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin
