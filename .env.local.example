# Copy this file to .env.local before running the app.

# Required local values from Supabase Dashboard -> Connect or Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local auth redirect URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for local bootstrap and admin staff management flows.
# Never expose this in browser code or in NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin

# Optional override for OpenAI model selection in server-side integrations.
OPENAI_MODEL=gpt-5.5
