# Copy this file to .env.local before running the app.

# PASTE THE REAL PROJECT URL HERE:
# Supabase Dashboard -> Connect (or Settings -> API) -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# PASTE THE REAL PUBLISHABLE KEY HERE:
# Supabase Dashboard -> Connect (or Settings -> API) -> Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_REAL_KEY

# Local dev URL for auth emails and metadata.
# Change this only if you run the app on a different local port.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server-only key for future imports/admin jobs.
# Supabase Dashboard -> Settings -> API -> service_role / secret key
# Never move this value into a NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVER_ONLY_KEY_IF_NEEDED

NEXT_PUBLIC_SCHOOL_NAME=Shri Veer Patta Senior Secondary School
NEXT_PUBLIC_APP_MODE=internal-admin
